# Docker environment configuration
# Copy this to .env.docker and update values

# Node.js Environment
NODE_ENV=production

# Backend Configuration
BACKEND_PORT=5000
PORT=5000

# Frontend Configuration
FRONTEND_PORT=3000
REACT_APP_API_URL=http://localhost:3000/api

# MongoDB Atlas Configuration (REQUIRED - No Local MongoDB)
# Get your connection string from MongoDB Atlas:
# 1. Go to https://www.mongodb.com/cloud/atlas
# 2. Click "Connect" → "Drivers" → Copy connection string
# Format: mongodb+srv://username:password@cluster-name.mongodb.net/database-name?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://your-username:your-password@your-cluster.mongodb.net/sentinel-stream?retryWrites=true&w=majority

# JWT Secrets (CRITICAL: Generate strong random values!)
# Generate with: openssl rand -base64 32
JWT_ACCESS_SECRET=your-very-strong-random-secret-here-min-32-chars
JWT_REFRESH_SECRET=another-strong-random-secret-min-32-chars

# Client URL
CLIENT_URL=http://localhost:3000
